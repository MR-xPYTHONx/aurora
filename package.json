{
  "name": "aurora",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "echo \"No test script configured\"",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "db:generate": "pnpm --filter @aurora/prisma run db:generate",
    "db:migrate": "pnpm --filter @aurora/prisma run db:migrate",
    "db:studio": "pnpm --filter @aurora/prisma run db:studio"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
